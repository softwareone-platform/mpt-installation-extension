        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"EVT-1111-1111\",\n  \"object\": {\n    \"id\": \"{{agreement_id}}\",\n    \"name\": \"Playground Agreement\",\n    \"objectType\": \"Agreement\"\n  },\n  \"details\": {\n    \"eventType\": \"platform.commerce.agreement.status_changed\",\n    \"enqueueTime\": \"2026-03-06T12:00:00Z\",\n    \"deliveryTime\": \"2026-03-06T12:01:00Z\"\n  }\n}",
          "options": {
            "raw": {
              "language": "json"
            }
